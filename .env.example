# Required: HuggingFace token (https://huggingface.co/settings/tokens)
HF_TOKEN=

# LLM backend: local | openai
LLM_PROVIDER=local

# Medical LLM to use (any HuggingFace model ID)
# Options: BioMistral/BioMistral-7B | epfl-llm/meditron-7b | microsoft/BioGPT-Large
LLM_MODEL=BioMistral/BioMistral-7B

# Embedding model for vector retrieval (OpenAI)
# Options: text-embedding-3-small | text-embedding-3-large | text-embedding-ada-002
EMBEDDING_MODEL=text-embedding-3-small

# OpenAI API (used only when LLM_PROVIDER=openai)
OPENAI_API_KEY=
# Optional: custom compatible endpoint (leave empty for api.openai.com)
OPENAI_BASE_URL=

# PubMed API key (optional — raises rate limit from 3/s to 10/s)
# Get one free at: https://www.ncbi.nlm.nih.gov/account/
PUBMED_KEY=
